CHUTE_ENV=development
CHUTE_DRY_RUN=true
TELEGRAM_BOT_TOKEN=
TXLINE_API_BASE=https://txline-dev.txodds.com/api
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_API_TOKEN=
TXLINE_JWT=
# Must match TXLINE_NETWORK. Prefer Helius, Triton, or QuickNode.
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Mainnet RPC used only by /api/solana/rpc?network=mainnet and by scripts/anchor_memo_mainnet.mjs.
# A Helius key works on both hosts (devnet.helius-rpc.com / mainnet.helius-rpc.com) — same HELIUS_API_KEY covers both.
SOLANA_MAINNET_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
TXLINE_NETWORK=devnet
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# Set only once the TxODDS mainnet program is deployed and credentialed; leave empty until then.
TXLINE_MAINNET_PROGRAM_ID=
TXLINE_WORKER_URL=http://127.0.0.1:8100
TXLINE_WORKER_PORT=8100
# Worker automation (P1): enable periodic fixture/score sync with backoff
TXLINE_AUTOSYNC=false
TXLINE_FIXTURE_SYNC_MS=600000
TXLINE_SCORE_SYNC_MS=60000
# Shared secret protecting /internal/txline/* ingestion (required outside local dev)
CHUTE_SERVICE_TOKEN=
# API base the worker persists into
CHUTE_API_URL=http://127.0.0.1:8000
# Ephemeral/alternate SQLite path (tests set this automatically)
CHUTE_DB_PATH=
