{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "env": {
    "VITE_PUBLIC_APP_URL": {
      "description": "Public app URL for Phantom deep links",
      "required": false
    },
    "VITE_API_URL": {
      "description": "Backend API URL",
      "required": false
    },
    "VITE_SOLANA_RPC_URL": {
      "description": "Solana mainnet RPC (default: api.mainnet-beta.solana.com)",
      "required": false
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://backend-url.railway.app/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
