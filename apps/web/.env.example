# Obrigatório em produção. Em dev local, o front usa fallback para 127.0.0.1.
VITE_API_URL=http://localhost:8000
# Obrigatório em produção para deep links canônicos da Phantom.
VITE_PUBLIC_APP_URL=http://localhost:5174
# Helius Devnet RPC. Never commit a real API key.
VITE_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Configure only during the later Mainnet migration.
VITE_SOLANA_MAINNET_RPC_URL=
